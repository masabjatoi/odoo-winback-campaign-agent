# ============================================================
# Odoo Connection Configuration
# ============================================================
ODOO_URL=https://your-odoo-instance.com
ODOO_DB=your-odoo-database-name
ODOO_USERNAME=your-salesperson-username-email
ODOO_API_KEY=your-odoo-xmlrpc-api-key

# ============================================================
# LLM Providers Configuration
# ============================================================
LLM_PROVIDER=mistral # Options: 'mistral', 'gemini' (or 'google'), 'groq'

# Provider API Keys (Fill in the one matching your LLM_PROVIDER)
GEMINI_API_KEY=your-google-gemini-api-key
groq_api_key=your-groq-api-key
MISTRAL_API_KEY=your-mistral-api-key

# ============================================================
# Win-Back Campaign Drip Parameters
# ============================================================
INACTIVITY_THRESHOLD_DAYS=60
WINBACK_INTERVAL_DAYS=7
WINBACK_OFFER_EMAIL2=WELCOME10
MAX_WINBACK_EMAILS=3
FINAL_WAIT_DAYS=7

# ============================================================
# Environment / Testing Settings
# ============================================================
# Set to 'true' to bypass Odoo writes and redirect outreach to test accounts.
# Set to 'false' to enable Odoo chatter logs, activity scheduler, and actual customer emails.
TEST_MODE=true

# Developer test email recipient
TEST_EMAIL_TO=developer-receiver@gmail.com

# Gmail SMTP Credentials (used for sending testing emails when TEST_MODE=true)
GMAIL_SMTP_USER=developer-sender@gmail.com
GMAIL_SMTP_APP_PASSWORD=your-gmail-smtp-app-specific-password
