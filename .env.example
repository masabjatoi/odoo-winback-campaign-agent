# ============================================================
# Odoo Connection Configuration
# ============================================================
ODOO_URL=https://your-odoo-instance.com
ODOO_DB=your-odoo-database-name
ODOO_USERNAME=your-salesperson-username-email
ODOO_API_KEY=your-odoo-xmlrpc-api-key

# ============================================================
# LLM Provider Configuration
# ============================================================
LLM_PROVIDER=mistral  # Options: 'mistral', 'gemini' (or 'google'), 'groq'

# Provider API Keys (fill in the one matching your LLM_PROVIDER)
MISTRAL_API_KEY=your-mistral-api-key
GEMINI_API_KEY=your-google-gemini-api-key
groq_api_key=your-groq-api-key

# ============================================================
# NOTE: All campaign behavior parameters (inactivity threshold,
# email interval days, max emails, segment by category,
# auto-reply mode, recipient override, promo code) are
# configured directly inside Odoo under:
#   Settings > General Settings > Lisa AI Win-Back section
# No need to set them here.
# ============================================================

# ============================================================
# OPTIONAL: Confident AI (DeepEval test dashboard)
# Place your project API key in a separate .env.local file
# (never commit .env.local to Git):
#   CONFIDENT_API_KEY=confident_us_proj_xxxx
# ============================================================
